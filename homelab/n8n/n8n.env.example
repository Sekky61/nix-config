TZ=UTC
GENERIC_TIMEZONE=UTC

# n8n editor and callback URLs
N8N_HOST=localhost
N8N_PORT=5678
N8N_PROTOCOL=http
WEBHOOK_URL=http://localhost:5678/

# For local-first testing, disable secure cookie on plain HTTP.
# Change this to true when you put n8n behind HTTPS.
N8N_SECURE_COOKIE=false

# Keep executions tidy in a test setup.
EXECUTIONS_DATA_PRUNE=true
EXECUTIONS_DATA_MAX_AGE=168
