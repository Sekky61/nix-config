TZ=UTC
GENERIC_TIMEZONE=UTC

# n8n assumes it is exposed through the Tailscale hostname below.
# If that changes, update these external URLs to match.
# n8n editor and callback URLs
N8N_HOST=n8n.rhino-mora.ts.net
N8N_PORT=5678
N8N_PROTOCOL=https
N8N_EDITOR_BASE_URL=https://n8n.rhino-mora.ts.net/
WEBHOOK_URL=https://n8n.rhino-mora.ts.net/

# Use secure cookies when n8n is exposed over HTTPS.
N8N_SECURE_COOKIE=true

# Keep executions tidy in a test setup.
EXECUTIONS_DATA_PRUNE=true
EXECUTIONS_DATA_MAX_AGE=168
