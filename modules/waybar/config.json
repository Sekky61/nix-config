{
  "layer": "top",
  "height": 30,
  "margin-top": 2,
  "margin-left": 10,
  "margin-bottom": 0,
  "margin-right": 10,
  "spacing": 0,
  "modules-left": [
    "custom/launcher",
    "custom/window-name",
    "custom/separator",
    "cpu",
    "memory",
    "temperature",
    "custom/filler",
    "custom/playerctl",
    "custom/filler",
    "disk",
    "custom/filler",
    "custom/blueman"
  ],
  "modules-center": [
    "hyprland/workspaces"
  ],
  "modules-right": [
    "battery",
    "backlight",
    "pulseaudio",
    "custom/separator",
    "network",
    "tray",
    "clock"
  ],
  "custom/playerctl": {
    "format": "[<span foreground='#46c880'> пЕД </span> <span>{}</span> ]",
    "return-type": "json",
    "max-length": 55,
    "exec": "playerctl -a metadata --format '{\"text\": \"{{playerName}}\"}' -F",
    "on-click": "playerctl play-pause",
    "on-click-middle": "playerctl previous",
    "on-click-right": "playerctl next",
    "format-icons": {
      "Playing": "<span foreground='#46c880'> пЕД </span>",
      "Paused": "<span foreground='#cdd6f4'> у∞П• </span>"
    }
  },
  "disk": {
    "interval": 1,
    "format": "<span color=\"#68b0d6\">пВ†</span>\u2003{}% ",
    "on-click": "filelight /",
    "on-click-right": "filelight /home/"
  },
  "hyprland/workspaces": {
    "all-outputs": true,
    "active-only": false,
    "separate-outputs": true,
    "on-click": "activate",
    "format": "{icon}",
    "on-scroll-up": "hyprctl dispatch workspace e+1",
    "on-scroll-down": "hyprctl dispatch workspace e-1",
    "format-icons": {
      "1": "пДМ",
      "2": "пДМ",
      "3": "пДМ",
      "4": "пДМ",
      "5": "пДМ",
      "6": "пДМ",
      "7": "пДМ",
      "8": "пДМ",
      "9": "пДМ",
      "urgent": "пБ™",
      "active": "пЖТ",
      "default": "пДС"
    }
  },
  "tray": {
    "icon-size": 20,
    "spacing": 8
  },
  "custom/filler": {
    "format": " пСД"
  },
  "custom/clock-icon": {
    "format": "пАУ"
  },
  "clock": {
    "format": "<b>{:%H:%M}</b>",
    "format-alt": "<b>{:%a.%d,%b}</b>",
    "tooltip-format": "<big>{:%B %Y}</big>\n<tt><small>{calendar}</small></tt>"
  },
  "cpu": {
    "interval": 10,
    "format": "пГГ {usage}% ",
    "max-length": 10,
    "on-click": "htop"
  },
  "memory": {
    "interval": 30,
    "format": "оИі {}% ",
    "format-alt": "пС≤ {used:0.1f}G",
    "max-length": 10,
    "on-click-right": "htop"
  },
  "backlight": {
    "device": "amdgpu_bl1",
    "format": "{icon} {percent} ",
    "tooltip": false,
    "format-icons": [
      "оОН",
      "оПУ",
      "оПС",
      "оПП",
      "оПО",
      "оПН",
      "оПК",
      "оПИ",
      "оОЫ"
    ]
  },
  "network": {
    "format-wifi": "у∞ТҐ {essid}",
    "format-alt": "у∞ТҐ {bandwidthTotalBits}",
    "on-click": "kitty nmtui",
    "on-click-right": "nm-connection-editor",
    "format-ethernet": "о∞Я wired",
    "tooltip-format": "{essid} {signalStrength}%",
    "format-disconnected": ""
  },
  "pulseaudio": {
    "format": "{icon} <b>{volume}</b>",
    "format-bluetooth": "пА• {volume}",
    "format-bluetooth-muted": "пЪ© пКФ",
    "tooltip": false,
    "format-muted": "о§≤",
    "format-icons": {
      "default": [
        "у∞ЭЯ",
        "пАІ",
        "у∞ХЊ",
        "пА®"
      ]
    },
    "on-click": "pactl set-sink-mute @DEFAULT_SINK@ toggle",
    "on-click-right": "pavucontrol"
  },
  "battery": {
    "bat": "BAT1",
    "interval": 10,
    "states": {
      "warning": 25,
      "critical": 15
    },
    "format": " {icon} {capacity}%",
    "format-charging": "у∞ВД {capacity}%",
    "format-icons": [
      "пХє",
      "пХЇ",
      "пХї",
      "пХЉ",
      "пХљ",
      "пХЊ",
      "пХњ",
      "пЦА",
      "пЦБ",
      "пХЄ"
    ],
    "max-length": 25,
    "tooltip": false
  },
  "custom/right-arr": {
    "format": " пБШ "
  },
  "custom/launcher": {
    "format": " пМУ"
  },
  "custom/separator": {
    "format": " "
  },
  "custom/window-name": {
    "format": " <b>{}</b>",
    "interval": 1,
    "exec": "hyprctl activewindow -j | jq -r '.initialTitle'"
  },
  "custom/blueman": {
    "format": " пКУ ",
    "on-click": "blueman"
  },
  "temperature": {
    "thermal-zone": 0,
    "critical-threshold": 80,
    "format-critical": " {temperatureC}¬∞C",
    "format": "пЛК {temperatureC}¬∞C"
  }
}
